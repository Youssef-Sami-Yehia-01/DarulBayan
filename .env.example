# Copy to .env and fill in. Production (Render) sets these as real env vars.

# Django
DJANGO_SECRET_KEY=            # generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_DEBUG=false            # "true" only in local development
DJANGO_ALLOWED_HOSTS=         # comma-separated, e.g. darulbayan.co.uk,www.darulbayan.co.uk
DJANGO_CSRF_TRUSTED_ORIGINS=  # comma-separated with scheme, e.g. https://darulbayan.co.uk

# Neon Postgres connection string (Neon dashboard > Connect)
DATABASE_URL=

# Cloudflare R2 (dashboard > R2 > Manage API tokens)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
